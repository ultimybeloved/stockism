{
  "name": "stockism",
  "version": "2.0.0",
  "description": "Lookism Character Stock Exchange - Community Edition",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator",
    "emulators": "firebase emulators:start --only auth,firestore,functions",
    "seed:emulator": "node scripts/seed-emulator.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "sync:chars": "node scripts/sync-chars.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .js,.jsx",
    "deploy:functions": "node scripts/deploy-functions.cjs"
  },
  "dependencies": {
    "@sentry/react": "^10.52.0",
    "canvas-confetti": "^1.9.4",
    "firebase": "^10.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "firebase-admin": "^11.11.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^4.1.5"
  }
}
